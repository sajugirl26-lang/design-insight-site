---
import Layout from '../layouts/Layout.astro';
import { getTimeline, getCategories, getKeywords } from '../scripts/data';

const timeline = getTimeline();
const { categories } = getCategories();
const keywordsData = getKeywords();

const totalCards = timeline.total_cards;
const totalInsights = timeline.cards.reduce((sum: number, c: any) => sum + c.insights.length, 0);
const channels = new Set(timeline.cards.map((c: any) => c.channel));
const keywordsCount = Object.keys(keywordsData.keywords || {}).length;

// Top keywords by frequency
const topKeywords = Object.entries(keywordsData.keywords || {})
  .map(([key, val]: [string, any]) => ({ keyword: key, count: val.total_count }))
  .sort((a, b) => b.count - a.count)
  .slice(0, 30);

const maxKwCount = topKeywords[0]?.count || 1;

// Category stats
const activeCategories = categories.filter((c: any) => c.count > 0)
  .sort((a: any, b: any) => b.count - a.count);
---

<Layout title="총정리">
  <section class="overview-section">
    <div class="page-header">
      <h1 class="section-title">총정리</h1>
      <p class="section-subtitle">수집된 데이터의 종합 현황을 한눈에 확인합니다</p>
    </div>

    <!-- Stats -->
    <div class="stats-grid">
      <div class="stat-card">
        <div class="stat-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>
        </div>
        <div class="stat-number">{totalCards}</div>
        <div class="stat-label">분석 영상</div>
      </div>
      <div class="stat-card accent">
        <div class="stat-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/></svg>
        </div>
        <div class="stat-number">{totalInsights}</div>
        <div class="stat-label">추출 인사이트</div>
      </div>
      <div class="stat-card">
        <div class="stat-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
        </div>
        <div class="stat-number">{channels.size}</div>
        <div class="stat-label">활성 채널</div>
      </div>
      <div class="stat-card">
        <div class="stat-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"/></svg>
        </div>
        <div class="stat-number">{keywordsCount}</div>
        <div class="stat-label">키워드</div>
      </div>
    </div>

    <!-- Keywords -->
    {topKeywords.length > 0 && (
      <div class="section-block">
        <h2>주요 키워드 Top 30</h2>
        <div class="keywords-cloud">
          {topKeywords.map((kw, i) => {
            const size = 0.75 + (kw.count / maxKwCount) * 0.5;
            const opacity = 0.5 + (kw.count / maxKwCount) * 0.5;
            return (
              <span class="keyword-chip" style={`font-size: ${size}rem; opacity: ${opacity}`}>
                {kw.keyword}
                <span class="kw-count">{kw.count}</span>
              </span>
            );
          })}
        </div>
      </div>
    )}

    <!-- Categories -->
    {activeCategories.length > 0 && (
      <div class="section-block">
        <h2>카테고리별 분포</h2>
        <div class="category-bars">
          {activeCategories.map((cat: any) => {
            const pct = Math.min(100, (cat.count / Math.max(1, activeCategories[0].count)) * 100);
            return (
              <div class="cat-bar-item">
                <div class="cat-bar-label">{cat.name_ko}</div>
                <div class="cat-bar-track">
                  <div class="cat-bar-fill" style={`width: ${pct}%`}>
                    <span class="cat-bar-inner-count">{cat.count}</span>
                  </div>
                </div>
              </div>
            );
          })}
        </div>
      </div>
    )}

    <div class="section-block">
      <div class="note-box">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        <p>메타 분석(WF3)이 실행되면 트렌드, 크로스채널 패턴, 내러티브가 여기에 추가됩니다.</p>
      </div>
    </div>
  </section>
</Layout>

<style>
  .overview-section {
    max-width: 860px;
    margin: 0 auto;
  }

  .page-header {
    margin-bottom: 2.5rem;
  }

  /* Stats */
  .stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.875rem;
    margin-bottom: 3rem;
  }
  .stat-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: 1.25rem;
    text-align: center;
    transition: transform var(--duration) var(--ease);
  }
  .stat-card:hover {
    transform: translateY(-2px);
  }
  .stat-card.accent {
    border-color: var(--color-accent);
    background: linear-gradient(180deg, rgba(124,124,247,0.06) 0%, var(--color-surface) 100%);
  }
  .stat-icon {
    color: var(--color-text-tertiary);
    margin-bottom: 0.5rem;
    display: flex;
    justify-content: center;
  }
  .stat-card.accent .stat-icon {
    color: var(--color-accent);
  }
  .stat-number {
    font-size: 2rem;
    font-weight: 800;
    color: var(--color-text);
    font-variant-numeric: tabular-nums;
    line-height: 1;
    margin-bottom: 0.25rem;
  }
  .stat-card.accent .stat-number {
    color: var(--color-accent);
  }
  .stat-label {
    font-size: var(--fs-xs);
    color: var(--color-text-tertiary);
    font-weight: 500;
  }

  /* Section blocks */
  .section-block {
    margin-bottom: 3rem;
  }
  .section-block h2 {
    font-family: var(--font-serif);
    font-size: var(--fs-h2);
    font-weight: 700;
    margin-bottom: 1.25rem;
    letter-spacing: -0.01em;
  }

  /* Keywords */
  .keywords-cloud {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    align-items: center;
    padding: 1.25rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--radius-lg);
  }
  .keyword-chip {
    background: var(--color-tag-bg);
    color: var(--color-tag-text);
    padding: 0.3rem 0.75rem;
    border-radius: var(--radius-full);
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    transition: transform var(--duration) var(--ease);
  }
  .keyword-chip:hover {
    transform: scale(1.05);
  }
  .kw-count {
    font-size: 0.6rem;
    opacity: 0.5;
    font-weight: 600;
  }

  /* Category bars */
  .category-bars {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }
  .cat-bar-item {
    display: grid;
    grid-template-columns: 140px 1fr;
    align-items: center;
    gap: 1rem;
  }
  .cat-bar-label {
    font-size: var(--fs-small);
    text-align: right;
    color: var(--color-text-secondary);
    font-weight: 500;
  }
  .cat-bar-track {
    height: 28px;
    background: var(--color-surface);
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--radius);
    overflow: hidden;
  }
  .cat-bar-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--color-accent) 0%, var(--color-accent-hover) 100%);
    border-radius: var(--radius);
    display: flex;
    align-items: center;
    justify-content: flex-end;
    padding-right: 0.5rem;
    min-width: 2.5rem;
    transition: width 0.4s var(--ease);
  }
  .cat-bar-inner-count {
    font-size: var(--fs-xs);
    font-weight: 700;
    color: white;
  }

  /* Note */
  .note-box {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    padding: 1rem 1.25rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--radius);
    color: var(--color-text-secondary);
    font-size: var(--fs-small);
  }
  .note-box svg {
    flex-shrink: 0;
    margin-top: 0.05rem;
    color: var(--color-accent);
  }

  /* Responsive */
  @media (max-width: 768px) {
    .stats-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .cat-bar-item {
      grid-template-columns: 100px 1fr;
      gap: 0.5rem;
    }
    .cat-bar-label {
      font-size: var(--fs-xs);
    }
    .cat-bar-track {
      height: 24px;
    }
  }

  @media (max-width: 480px) {
    .stats-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 0.625rem;
    }
    .stat-card {
      padding: 1rem;
    }
    .stat-number {
      font-size: 1.5rem;
    }
  }
</style>
