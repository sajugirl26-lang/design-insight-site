---
import Layout from '../layouts/Layout.astro';
import { getTimeline, getCategories, getKeywords } from '../scripts/data';

const timeline = getTimeline();
const { categories } = getCategories();
const keywordsData = getKeywords();

const totalCards = timeline.total_cards;
const totalInsights = timeline.cards.reduce((sum: number, c: any) => sum + c.insights.length, 0);
const channels = new Set(timeline.cards.map((c: any) => c.channel));
const keywordsCount = Object.keys(keywordsData.keywords || {}).length;

// Top keywords by frequency
const topKeywords = Object.entries(keywordsData.keywords || {})
  .map(([key, val]: [string, any]) => ({ keyword: key, count: val.total_count }))
  .sort((a, b) => b.count - a.count)
  .slice(0, 30);

const maxKwCount = topKeywords[0]?.count || 1;

// Category stats
const activeCategories = categories.filter((c: any) => c.count > 0)
  .sort((a: any, b: any) => b.count - a.count);
---

<Layout title="총정리">
  <section class="overview-section">
    <div class="page-header">
      <h1 class="section-title">총정리</h1>
      <p class="section-subtitle">수집된 데이터의 종합 현황을 한눈에 확인합니다</p>
    </div>

    <!-- Stats -->
    <div class="stats-grid">
      <div class="stat-card">
        <div class="stat-number">{totalCards}</div>
        <div class="stat-label">분석 영상</div>
      </div>
      <div class="stat-card accent">
        <div class="stat-number">{totalInsights}</div>
        <div class="stat-label">추출 인사이트</div>
      </div>
      <div class="stat-card">
        <div class="stat-number">{channels.size}</div>
        <div class="stat-label">활성 채널</div>
      </div>
      <div class="stat-card">
        <div class="stat-number">{keywordsCount}</div>
        <div class="stat-label">키워드</div>
      </div>
    </div>

    <!-- Keywords -->
    {topKeywords.length > 0 && (
      <div class="section-block">
        <h2>주요 키워드 Top 30</h2>
        <div class="keywords-cloud">
          {topKeywords.map((kw, i) => {
            const size = 0.75 + (kw.count / maxKwCount) * 0.5;
            const opacity = 0.5 + (kw.count / maxKwCount) * 0.5;
            return (
              <span class="keyword-chip" style={`font-size: ${size}rem; opacity: ${opacity}`}>
                {kw.keyword}
                <span class="kw-count">{kw.count}</span>
              </span>
            );
          })}
        </div>
      </div>
    )}

    <!-- Categories -->
    {activeCategories.length > 0 && (
      <div class="section-block">
        <h2>카테고리별 분포</h2>
        <div class="category-bars">
          {activeCategories.map((cat: any) => {
            const pct = Math.min(100, (cat.count / Math.max(1, activeCategories[0].count)) * 100);
            return (
              <div class="cat-bar-item">
                <div class="cat-bar-label">{cat.name_ko}</div>
                <div class="cat-bar-track">
                  <div class="cat-bar-fill" style={`width: ${pct}%`}>
                    <span class="cat-bar-inner-count">{cat.count}</span>
                  </div>
                </div>
              </div>
            );
          })}
        </div>
      </div>
    )}

    <div class="section-block">
      <div class="note-box">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        <p>메타 분석(WF3)이 실행되면 트렌드, 크로스채널 패턴, 내러티브가 여기에 추가됩니다.</p>
      </div>
    </div>
  </section>
</Layout>

<style>
  .overview-section {
    max-width: 860px;
    margin: 0 auto;
  }

  .page-header {
    margin-bottom: 2rem;
  }

  /* Stats */
  .stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.75rem;
    margin-bottom: 2.5rem;
  }
  .stat-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 1.25rem;
    text-align: center;
    transition: border-color var(--duration) var(--ease);
  }
  .stat-card:hover {
    border-color: #ccc;
  }
  .stat-card.accent {
    border-color: var(--color-accent);
  }
  .stat-number {
    font-family: var(--font-stat);
    font-size: 2rem;
    color: var(--color-text);
    line-height: 1;
    margin-bottom: 0.25rem;
  }
  .stat-card.accent .stat-number {
    color: var(--color-accent);
  }
  .stat-label {
    font-family: var(--font-label);
    font-size: var(--fs-xs);
    color: var(--color-text-tertiary);
    font-weight: 500;
  }

  /* Section blocks */
  .section-block {
    margin-bottom: 2.5rem;
  }
  .section-block h2 {
    font-family: var(--font-label);
    font-size: var(--fs-h2);
    font-weight: 700;
    margin-bottom: 1rem;
    letter-spacing: -0.01em;
  }

  /* Keywords */
  .keywords-cloud {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    align-items: center;
    padding: 1.25rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
  }
  .keyword-chip {
    background: var(--color-tag-bg);
    color: var(--color-accent);
    padding: 0.25rem 0.625rem;
    border-radius: 4px;
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    transition: transform var(--duration) var(--ease);
  }
  .keyword-chip:hover {
    transform: scale(1.05);
  }
  .kw-count {
    font-family: var(--font-label);
    font-size: 0.6rem;
    opacity: 0.5;
    font-weight: 600;
  }

  /* Category bars */
  .category-bars {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .cat-bar-item {
    display: grid;
    grid-template-columns: 140px 1fr;
    align-items: center;
    gap: 0.75rem;
  }
  .cat-bar-label {
    font-size: var(--fs-small);
    text-align: right;
    color: var(--color-text-secondary);
    font-weight: 500;
  }
  .cat-bar-track {
    height: 26px;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 4px;
    overflow: hidden;
  }
  .cat-bar-fill {
    height: 100%;
    background: var(--color-accent);
    border-radius: 4px;
    display: flex;
    align-items: center;
    justify-content: flex-end;
    padding-right: 0.5rem;
    min-width: 2.5rem;
    transition: width 0.4s var(--ease);
  }
  .cat-bar-inner-count {
    font-family: var(--font-label);
    font-size: var(--fs-xs);
    font-weight: 700;
    color: #fff;
  }

  /* Note */
  .note-box {
    display: flex;
    align-items: flex-start;
    gap: 0.625rem;
    padding: 0.875rem 1rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    color: var(--color-text-secondary);
    font-size: var(--fs-small);
  }
  .note-box svg {
    flex-shrink: 0;
    margin-top: 0.05rem;
    color: var(--color-accent);
  }

  /* Responsive */
  @media (max-width: 768px) {
    .stats-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .cat-bar-item {
      grid-template-columns: 100px 1fr;
      gap: 0.5rem;
    }
    .cat-bar-label {
      font-size: var(--fs-xs);
    }
    .cat-bar-track {
      height: 22px;
    }
  }

  @media (max-width: 480px) {
    .stats-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 0.5rem;
    }
    .stat-card {
      padding: 1rem;
    }
    .stat-number {
      font-size: 1.5rem;
    }
  }
</style>
