---
import Layout from '../layouts/Layout.astro';
import { getChannels } from '../scripts/data';

const { channels, groups } = getChannels();

const groupColors: Record<string, string> = {
  vision_opinion: '#f0c040',
  ai_3d_motion: '#7eb8f7',
  media_art: '#f06292',
  studio_business: '#4ecdc4',
  branding_process: '#b39ddb',
};

// Group channels
const grouped = Object.entries(groups).map(([groupId, groupInfo]: [string, any]) => ({
  id: groupId,
  ...groupInfo,
  channels: channels.filter((ch: any) => ch.group === groupId),
}));

const totalActive = channels.filter((ch: any) => ch.total_videos > 0).length;
---

<Layout title="유튜버">
  <section class="youtubers-section">
    <div class="page-header">
      <h1 class="section-title">디자인 유튜버 25</h1>
      <p class="section-subtitle">큐레이션 대상 채널 목록 &middot; 활성 {totalActive}개 채널</p>
    </div>

    {grouped.map(group => (
      <div class="channel-group">
        <div class="group-header">
          <div class="group-dot" style={`background: ${groupColors[group.id] || '#666'}`}></div>
          <div>
            <h2>{group.name_ko}</h2>
            <p class="group-desc">{group.description}</p>
          </div>
        </div>

        <div class="channels-grid">
          {group.channels.map((ch: any) => (
            <a href={ch.url} target="_blank" rel="noopener" class="channel-card" style={`--group-color: ${groupColors[group.id] || '#666'}`}>
              <div class="channel-top">
                <div class="channel-avatar">
                  {ch.name.charAt(0).toUpperCase()}
                </div>
                <div class="channel-info">
                  <h3>{ch.name}</h3>
                  <span class="subs">{ch.subscribers}</span>
                </div>
              </div>
              <p class="channel-desc">{ch.description}</p>
              {(ch.total_videos > 0 || ch.total_insights > 0) && (
                <div class="channel-stats">
                  {ch.total_videos > 0 && (
                    <div class="ch-stat">
                      <span class="ch-stat-num">{ch.total_videos}</span>
                      <span class="ch-stat-label">영상</span>
                    </div>
                  )}
                  {ch.total_insights > 0 && (
                    <div class="ch-stat">
                      <span class="ch-stat-num">{ch.total_insights}</span>
                      <span class="ch-stat-label">인사이트</span>
                    </div>
                  )}
                  {ch.latest_date && (
                    <div class="ch-stat">
                      <span class="ch-stat-label">최근 {ch.latest_date}</span>
                    </div>
                  )}
                </div>
              )}
              {ch.total_videos === 0 && (
                <div class="channel-pending">
                  <span>대기 중</span>
                </div>
              )}
            </a>
          ))}
        </div>
      </div>
    ))}
  </section>
</Layout>

<style>
  .youtubers-section {
    max-width: 960px;
    margin: 0 auto;
  }

  .page-header {
    margin-bottom: 2rem;
  }

  /* Group */
  .channel-group {
    margin-bottom: 2.5rem;
  }
  .group-header {
    display: flex;
    align-items: flex-start;
    gap: 0.625rem;
    margin-bottom: 1rem;
  }
  .group-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    margin-top: 0.4rem;
    flex-shrink: 0;
  }
  .group-header h2 {
    font-family: var(--font-label);
    font-size: var(--fs-h2);
    font-weight: 700;
    letter-spacing: -0.01em;
    margin-bottom: 0.125rem;
  }
  .group-desc {
    color: var(--color-text-secondary);
    font-size: var(--fs-small);
  }

  /* Grid */
  .channels-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 0.75rem;
  }

  /* Card */
  .channel-card {
    display: flex;
    flex-direction: column;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 1.125rem;
    color: var(--color-text);
    transition: all var(--duration) var(--ease);
    text-decoration: none;
  }
  .channel-card:hover {
    border-color: var(--group-color, var(--color-accent));
    box-shadow: var(--shadow-sm);
    color: var(--color-text);
  }

  .channel-top {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    margin-bottom: 0.5rem;
  }
  .channel-avatar {
    width: 36px;
    height: 36px;
    border-radius: 6px;
    background: var(--group-color, var(--color-accent-dim));
    color: #0a0a0a;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-label);
    font-weight: 700;
    font-size: 0.875rem;
    flex-shrink: 0;
  }
  .channel-info {
    flex: 1;
    min-width: 0;
  }
  .channel-info h3 {
    font-size: var(--fs-body);
    font-weight: 600;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .subs {
    font-family: var(--font-label);
    font-size: var(--fs-xs);
    color: var(--color-text-tertiary);
  }

  .channel-desc {
    font-size: var(--fs-small);
    color: var(--color-text-secondary);
    line-height: var(--lh-body);
    margin-bottom: 0.75rem;
    flex: 1;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .channel-stats {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding-top: 0.5rem;
    border-top: 1px solid var(--color-border);
  }
  .ch-stat {
    display: flex;
    align-items: baseline;
    gap: 0.25rem;
  }
  .ch-stat-num {
    font-family: var(--font-stat);
    font-weight: 400;
    font-size: var(--fs-body);
    color: var(--color-accent);
  }
  .ch-stat-label {
    font-family: var(--font-label);
    font-size: var(--fs-xs);
    color: var(--color-text-tertiary);
  }

  .channel-pending {
    padding-top: 0.5rem;
    border-top: 1px solid var(--color-border);
  }
  .channel-pending span {
    font-size: var(--fs-xs);
    color: var(--color-text-tertiary);
    font-style: italic;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .channels-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
