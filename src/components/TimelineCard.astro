---
interface Props {
  videoId: string;
  channel: string;
  channelGroup: string;
  titleKo: string;
  summaryShortKo: string;
  summaryKo: string;
  categories: string[];
  keywords: string[];
  insights: any[];
  youtubeUrl: string;
  publishedAt: string;
  date?: string;
}

const {
  videoId,
  channel,
  channelGroup,
  titleKo,
  summaryShortKo,
  summaryKo,
  categories,
  keywords,
  insights,
  youtubeUrl,
  publishedAt,
  date,
} = Astro.props;

const groupColors: Record<string, string> = {
  vision_opinion: '#c08e10',
  ai_3d_motion: '#2563eb',
  media_art: '#d63384',
  studio_business: '#0d9488',
  branding_process: '#7c3aed',
};

const stanceLabels: Record<string, string> = {
  positive: 'Positive',
  negative: 'Negative',
  neutral: 'Neutral',
  mixed: 'Mixed',
};

const noveltyLabels: Record<string, string> = {
  high: 'High',
  medium: 'Med',
  low: 'Low',
};

const accentColor = groupColors[channelGroup] || '#f0c040';
const displayDate = date || publishedAt;
---

<article class="timeline-card" data-video-id={videoId} data-categories={JSON.stringify(categories)}>
  <div class="card-accent" style={`background: ${accentColor}`}></div>

  <!-- Bookmark — top right -->
  <div class="card-state-top">
    <button class="btn-bookmark" data-video-id={videoId} title="관심 저장">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 21l-7-5-7 5V5a2 2 0 012-2h10a2 2 0 012 2z"/></svg>
    </button>
  </div>

  <div class="card-body">
    <div class="card-meta">
      <span class="card-channel" style={`color: ${accentColor}`}>{channel}</span>
      <span class="meta-dot"></span>
      <time class="card-date">{displayDate}</time>
    </div>

    <h3 class="card-title">{titleKo}</h3>

    <p class="card-summary">{summaryShortKo}</p>

    <div class="card-bottom">
      <div class="card-actions">
        <button class="btn-expand" data-target={`modal-${videoId}`}>
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 17l9.2-9.2M17 17V7H7"/></svg>
          읽기
        </button>
        <a href={youtubeUrl} target="_blank" rel="noopener" class="btn-youtube" title="YouTube에서 보기">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M10 15l5.19-3L10 9v6m11.56-7.83c.13.47.22 1.1.28 1.9.07.8.1 1.49.1 2.09L22 12c0 2.19-.16 3.8-.44 4.83-.25.9-.83 1.48-1.73 1.73-.47.13-1.33.22-2.65.28-1.3.07-2.49.1-3.59.1L12 19c-4.19 0-6.8-.16-7.83-.44-.9-.25-1.48-.83-1.73-1.73-.13-.47-.22-1.1-.28-1.9-.07-.8-.1-1.49-.1-2.09L2 12c0-2.19.16-3.8.44-4.83.25-.9.83-1.48 1.73-1.73.47-.13 1.33-.22 2.65-.28 1.3-.07 2.49-.1 3.59-.1L12 5c4.19 0 6.8.16 7.83.44.9.25 1.48.83 1.73 1.73z"/></svg>
          YouTube
        </a>
      </div>
      <!-- Read-check — bottom right -->
      <button class="btn-read-check" data-video-id={videoId} title="읽음 처리">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
      </button>
    </div>
  </div>

  <!-- Modal -->
  <div class="card-modal" id={`modal-${videoId}`}>
    <div class="modal-backdrop"></div>
    <div class="modal-panel">
      <div class="modal-top-bar">
        <div class="modal-channel" style={`color: ${accentColor}`}>{channel}</div>
        <button class="modal-close" data-close={`modal-${videoId}`}>
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </button>
      </div>

      <div class="modal-scroll">
        <div class="modal-header">
          <time class="modal-date">{displayDate}</time>
          <h2>{titleKo}</h2>
          <div class="modal-links">
            <a href={youtubeUrl} target="_blank" rel="noopener" class="yt-link">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M10 15l5.19-3L10 9v6m11.56-7.83c.13.47.22 1.1.28 1.9.07.8.1 1.49.1 2.09L22 12c0 2.19-.16 3.8-.44 4.83-.25.9-.83 1.48-1.73 1.73-.47.13-1.33.22-2.65.28-1.3.07-2.49.1-3.59.1L12 19c-4.19 0-6.8-.16-7.83-.44-.9-.25-1.48-.83-1.73-1.73-.13-.47-.22-1.1-.28-1.9-.07-.8-.1-1.49-.1-2.09L2 12c0-2.19.16-3.8.44-4.83.25-.9.83-1.48 1.73-1.73.47-.13 1.33-.22 2.65-.28 1.3-.07 2.49-.1 3.59-.1L12 5c4.19 0 6.8.16 7.83.44.9.25 1.48.83 1.73 1.73z"/></svg>
              YouTube 원본
            </a>
          </div>
        </div>

        <hr class="divider" />

        <section class="modal-section">
          <h4>요약</h4>
          <div class="modal-summary">
            {summaryKo.split('\n').map((p: string) => p.trim() && <p>{p}</p>)}
          </div>
        </section>

        <section class="modal-section">
          <h4>인사이트 <span class="section-count">{insights.length}</span></h4>
          <div class="insights-list">
            {insights.map((ins: any, idx: number) => (
              <div class="insight-item">
                <div class="insight-num">{String(idx + 1).padStart(2, '0')}</div>
                <div class="insight-content">
                  <div class="insight-header">
                    <span class="insight-topic">{ins.topic_ko}</span>
                    <div class="insight-badges">
                      <span class={`badge stance-${ins.stance}`}>{stanceLabels[ins.stance] || ins.stance}</span>
                      <span class={`badge novelty-${ins.novelty_raw}`}>{noveltyLabels[ins.novelty_raw] || ins.novelty_raw}</span>
                    </div>
                  </div>
                  <p class="insight-text">{ins.text_ko}</p>
                  {ins.actionability?.actionable && ins.actionability.advice && (
                    <div class="insight-advice">
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
                      {ins.actionability.advice}
                    </div>
                  )}
                  {ins.keywords?.length > 0 && (
                    <div class="insight-keywords">
                      {ins.keywords.map((kw: string) => (
                        <span class="tag small">{kw}</span>
                      ))}
                    </div>
                  )}
                </div>
              </div>
            ))}
          </div>
        </section>

        {keywords.length > 0 && (
          <section class="modal-section">
            <h4>키워드</h4>
            <div class="keywords-list">
              {keywords.map((kw: string) => (
                <span class="tag">{kw}</span>
              ))}
            </div>
          </section>
        )}
      </div>
    </div>
  </div>
</article>

<style>
  /* ==================== Card ==================== */
  .timeline-card {
    position: relative;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    overflow: hidden;
    transition: border-color var(--duration) var(--ease),
                box-shadow var(--duration) var(--ease);
  }
  .timeline-card:hover {
    border-color: #ccc;
    box-shadow: var(--shadow-md);
  }

  .card-accent {
    height: 2px;
    width: 100%;
  }

  .card-body {
    padding: 1.125rem 1.25rem 1rem;
  }

  .card-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.5rem;
    font-size: var(--fs-xs);
    font-family: var(--font-label);
  }
  .card-channel {
    font-weight: 600;
  }
  .meta-dot {
    width: 3px;
    height: 3px;
    border-radius: 50%;
    background: var(--color-text-tertiary);
  }
  .card-date {
    color: var(--color-text-tertiary);
  }

  .card-title {
    font-size: var(--fs-h3);
    font-weight: 700;
    line-height: var(--lh-tight);
    margin-bottom: 0.5rem;
    padding-right: 3.5rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-summary {
    font-size: var(--fs-small);
    color: var(--color-text-secondary);
    line-height: var(--lh-body);
    margin-bottom: 1rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* Bookmark — absolute top-right */
  .card-state-top {
    position: absolute;
    top: 0.5rem;
    right: 0.5rem;
    z-index: 2;
  }

  .btn-bookmark,
  .btn-read-check {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 10px;
    background: rgba(255, 255, 255, 0.85);
    backdrop-filter: blur(4px);
    border: 1px solid var(--color-border);
    color: var(--color-text-tertiary);
    cursor: pointer;
    transition: all var(--duration) var(--ease);
  }
  .btn-bookmark:hover {
    color: var(--color-accent);
    border-color: rgba(212, 160, 32, 0.3);
    background: rgba(212, 160, 32, 0.08);
  }
  .btn-read-check:hover {
    color: #059669;
    border-color: rgba(5, 150, 105, 0.2);
    background: rgba(5, 150, 105, 0.06);
  }

  .btn-bookmark.active {
    color: var(--color-accent);
    background: rgba(212, 160, 32, 0.12);
    border-color: rgba(212, 160, 32, 0.3);
  }
  .btn-bookmark.active svg {
    fill: var(--color-accent);
  }

  .btn-read-check.active {
    color: #059669;
    background: rgba(5, 150, 105, 0.08);
    border-color: rgba(5, 150, 105, 0.25);
  }
  .btn-read-check.active svg {
    fill: none;
    stroke: #059669;
    stroke-width: 3;
  }

  .timeline-card.is-read {
    opacity: 0.6;
  }
  .timeline-card.is-read:hover {
    opacity: 0.85;
  }

  .card-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 0.75rem;
  }

  .card-actions {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    flex-shrink: 0;
  }

  .btn-expand,
  .btn-youtube {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    padding: 0.4rem 0.875rem;
    border-radius: 6px;
    cursor: pointer;
    font-family: var(--font-label);
    font-size: var(--fs-xs);
    font-weight: 600;
    transition: all var(--duration) var(--ease);
    text-decoration: none;
  }
  .btn-expand {
    color: var(--color-accent);
  }
  .btn-expand:hover {
    background: var(--color-accent);
    border-color: var(--color-accent);
    color: #fff;
  }
  .btn-youtube {
    color: var(--color-text-secondary);
  }
  .btn-youtube:hover {
    background: rgba(255, 0, 0, 0.06);
    border-color: rgba(255, 68, 68, 0.3);
    color: #e53935;
  }

  /* ==================== Modal ==================== */
  .card-modal {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 200;
  }
  .card-modal.active {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .modal-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.4);
    backdrop-filter: blur(4px);
  }

  .modal-panel {
    position: relative;
    width: min(640px, calc(100% - 2rem));
    max-height: calc(100vh - 4rem);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    display: flex;
    flex-direction: column;
    animation: modalFadeIn 0.2s var(--ease);
    box-shadow: var(--shadow-lg);
  }

  @keyframes modalFadeIn {
    from { opacity: 0; transform: scale(0.95) translateY(10px); }
    to { opacity: 1; transform: scale(1) translateY(0); }
  }

  .modal-top-bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.875rem 1.25rem;
    border-bottom: 1px solid var(--color-border);
    flex-shrink: 0;
  }
  .modal-channel {
    font-family: var(--font-label);
    font-weight: 600;
    font-size: var(--fs-small);
  }
  .modal-close {
    background: none;
    border: none;
    color: var(--color-text-secondary);
    cursor: pointer;
    padding: 0.25rem;
    border-radius: 6px;
    transition: all var(--duration) var(--ease);
    display: flex;
    align-items: center;
  }
  .modal-close:hover {
    background: var(--color-surface-hover);
    color: var(--color-text);
  }

  .modal-scroll {
    flex: 1;
    overflow-y: auto;
    padding: 1.25rem;
  }

  .modal-header {
    margin-bottom: 0;
  }
  .modal-date {
    font-family: var(--font-label);
    font-size: var(--fs-xs);
    color: var(--color-text-tertiary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .modal-header h2 {
    font-size: var(--fs-h2);
    font-weight: 700;
    line-height: var(--lh-tight);
    margin-top: 0.375rem;
  }
  .modal-links {
    margin-top: 0.75rem;
  }
  .yt-link {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-family: var(--font-label);
    font-size: var(--fs-xs);
    color: var(--color-text-secondary);
    padding: 0.25rem 0.5rem;
    border-radius: 6px;
    border: 1px solid var(--color-border);
    transition: all var(--duration) var(--ease);
  }
  .yt-link:hover {
    border-color: #e53935;
    color: #e53935;
  }

  .divider {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 1.25rem 0;
  }

  /* Sections */
  .modal-section {
    margin-bottom: 1.75rem;
  }
  .modal-section h4 {
    font-family: var(--font-label);
    font-size: var(--fs-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-accent);
    margin-bottom: 0.75rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .section-count {
    font-size: var(--fs-xs);
    background: var(--color-accent-dim);
    color: var(--color-accent);
    padding: 0.1rem 0.4rem;
    border-radius: 4px;
    font-weight: 600;
  }

  .modal-summary p {
    margin-bottom: 0.75rem;
    font-size: var(--fs-body);
    line-height: var(--lh-loose);
    color: var(--color-text-secondary);
  }

  /* Insights */
  .insights-list {
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .insight-item {
    display: flex;
    gap: 0.875rem;
    padding: 0.875rem 0;
    border-bottom: 1px solid var(--color-border);
  }
  .insight-item:last-child {
    border-bottom: none;
  }
  .insight-num {
    font-family: var(--font-stat);
    font-size: var(--fs-small);
    color: var(--color-accent);
    padding-top: 0.125rem;
    flex-shrink: 0;
    width: 1.5rem;
  }
  .insight-content {
    flex: 1;
    min-width: 0;
  }
  .insight-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 0.5rem;
    margin-bottom: 0.375rem;
    flex-wrap: wrap;
  }
  .insight-topic {
    font-weight: 600;
    font-size: var(--fs-body);
    line-height: var(--lh-tight);
  }
  .insight-badges {
    display: flex;
    gap: 0.25rem;
    flex-shrink: 0;
  }
  .badge {
    font-family: var(--font-label);
    font-size: 0.625rem;
    padding: 0.125rem 0.375rem;
    border-radius: 4px;
    font-weight: 600;
    letter-spacing: 0.02em;
  }
  .stance-positive { background: #dcfce7; color: #166534; }
  .stance-negative { background: #fde2e2; color: #991b1b; }
  .stance-neutral { background: #f0f0f0; color: #666; }
  .stance-mixed { background: #ede9fe; color: #5b21b6; }
  .novelty-high { background: #fef3c7; color: #92400e; }
  .novelty-medium { background: #dbeafe; color: #1e40af; }
  .novelty-low { background: #f0f0f0; color: #888; }

  .insight-text {
    font-size: var(--fs-small);
    line-height: var(--lh-body);
    color: var(--color-text-secondary);
    margin-bottom: 0.5rem;
  }
  .insight-advice {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    font-size: var(--fs-small);
    color: #166534;
    background: #f0fdf4;
    padding: 0.5rem 0.75rem;
    border-radius: var(--radius);
    margin-bottom: 0.5rem;
    line-height: var(--lh-body);
  }
  .insight-advice svg {
    flex-shrink: 0;
    margin-top: 0.125rem;
  }
  .insight-keywords {
    display: flex;
    gap: 0.25rem;
    flex-wrap: wrap;
    margin-top: 0.25rem;
  }

  .keywords-list {
    display: flex;
    gap: 0.375rem;
    flex-wrap: wrap;
  }

  /* ==================== Responsive ==================== */
  @media (max-width: 768px) {
    .card-body {
      padding: 0.875rem 1rem 0.75rem;
    }

    .card-state-top {
      top: 0.375rem;
      right: 0.375rem;
    }
    .btn-bookmark,
    .btn-read-check {
      width: 36px;
      height: 36px;
    }
    .card-title {
      padding-right: 3.5rem;
    }

    .modal-panel {
      width: calc(100% - 1rem);
      max-height: calc(100vh - 2rem);
      border-radius: var(--radius);
    }

    .modal-scroll {
      padding: 1rem;
    }

    .insight-item {
      gap: 0.5rem;
    }
    .insight-num {
      display: none;
    }
  }
</style>
